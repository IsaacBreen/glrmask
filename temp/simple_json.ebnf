#![ignore(WS)]

root ::= value;
value ::= object | array | STRING | NUMBER | 'true' | 'false' | 'null';
object ::= '{' (pair (',' pair)*)? '}';
pair ::= STRING ':' value;
array ::= '[' (value (',' value)*)? ']';
STRING ::= '"' CHAR* '"';
CHAR ::= [^"\\] | '\\' .;
NUMBER ::= '-'? ('0' | [1-9] [0-9]*) ('.' [0-9]+)? ([eE] [+-]? [0-9]+)?;
WS ::= [ \t\n\r]+;
