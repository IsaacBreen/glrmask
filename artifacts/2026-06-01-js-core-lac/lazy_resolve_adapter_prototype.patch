+fn ensure_lazy_bundle_fragment_nodes(
+    graph: &mut LazyResolveGraph,
+    bundle: &NWA,
+    bundle_id: usize,
+    target_td_state: u32,
+) {
+    for local_state in 0..bundle.states().len() as u32 {
