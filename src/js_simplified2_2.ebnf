// Instruct the parser to ignore Whitespace and Comments between tokens.
#![ignore(IGNORE)]

program ::= statement_list? EOF;
EOF ::= '<|EOF|>';

// --- Lexical Grammar (Unchanged) ---
IGNORE ::= WS+ ;
WS ::= ( ' ' | '\t' | '\n' | '\r' )+ ;

// --- Statements (Simplified) ---
statement_list ::= IDENTIFIER+ ;

IDENTIFIER ::= [a-zA-Z_] [a-zA-Z0-9_]* ;