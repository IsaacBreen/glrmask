//_TEMPLATE_CHAR ::= [^`\\] | '\\' . ;

//template_literal ::= TEMPLATE_LITERAL ;
//TEMPLATE_LITERAL ::= '`' _TEMPLATE_CHARS '`' ;
TEMPLATE_LITERAL ::= '`' _TEMPLATE_CHARS '`' ;
_TEMPLATE_CHARS ::= _TEMPLATE_CHAR+ ;
_TEMPLATE_CHAR ::= [^`\\] | '\\' . ;

//template_literal ::= 'asdfasdfasdfasdfasdfsaf' ;

// Identifiers
IDENTIFIER ::= _IDENTIFIER_START _IDENTIFIER_PART* ;
_IDENTIFIER_START ::= [a-zA-Z] | '$' | '_' ;
_IDENTIFIER_PART ::= _IDENTIFIER_START | _DECIMAL_DIGIT ;
_HEX_DIGIT ::= [0-9a-fA-F] ;
