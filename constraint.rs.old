// ---------------------------------------------------------------------------
// Error Handling
// ---------------------------------------------------------------------------

mod error {
    use super::*;

    #[derive(Error, Debug)]
    pub enum BuildError {
        #[error("Grammar definition error: {0}")]
        Grammar(String),

        #[error("Tokenizer error: {0}")]
        Tokenizer(String),

        #[error("Serialization/Deserialization error: {0}")]
        Serde(#[from] serde_json::Error),

        #[error("Internal precomputation error: {0}")]
        Precompute(String),

        #[error("An unsupported epsilon token was found in the grammar")]
        EpsilonTokenNotSupported,
    }
}

// ---------------------------------------------------------------------------
// Configuration
// ---------------------------------------------------------------------------

mod config {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq, Eq, Default, Serialize, Deserialize)]
    pub enum TerminalAllowanceCheckMode {
        None,
        ImmediateSets,
        ImmediateProbe,
        #[default]
        StepProbe,
    }

    // Keeping JSONConvertible implementation for compatibility with existing JSON infrastructure
    impl JSONConvertible for TerminalAllowanceCheckMode {
        fn to_json(&self) -> JSONNode {
            let s = match self {
                TerminalAllowanceCheckMode::None => "none",
                TerminalAllowanceCheckMode::ImmediateSets => "immediate_sets",
                TerminalAllowanceCheckMode::ImmediateProbe => "immediate_probe",
                TerminalAllowanceCheckMode::StepProbe => "step_probe",
            };
            JSONNode::String(s.to_string())
        }

        fn from_json(node: JSONNode) -> Result<Self, String> {
            match node {
                JSONNode::String(s) => match s.as_str() {
                    "none" => Ok(TerminalAllowanceCheckMode::None),
                    "immediate_sets" => Ok(TerminalAllowanceCheckMode::ImmediateSets),
                    "immediate_probe" => Ok(TerminalAllowanceCheckMode::ImmediateProbe),
                    "step_probe" => Ok(TerminalAllowanceCheckMode::StepProbe),
                    other => Err(format!("Unknown TerminalAllowanceCheckMode '{}'", other)),
                },
                other => Err(format!(
                    "Expected JSON string for TerminalAllowanceCheckMode, got {:?}",
                    other
                )),
            }
        }
    }

    #[derive(Debug, Clone, Default, Serialize, Deserialize)]
    pub struct EngineConfig {
        pub trie1: Trie1Config,
        pub run_precompute4: bool,
        pub use_dummy_terminals: bool,
        pub dummy_terminal_map: BTreeMap<String, BTreeSet<Terminal>>,
        pub dummy_terminal_penalties: BTreeMap<String, usize>,
        pub post_commit_allow_check_mode: TerminalAllowanceCheckMode,
    }

    impl EngineConfig {
        pub fn off() -> Self { Self::default() }
    }
}

// ---------------------------------------------------------------------------
// Data Bundles (Types)
// ---------------------------------------------------------------------------

mod types {
    use super::*;

    /// Encapsulates all vocabulary and token mapping data.
    #[derive(Debug, Clone, Serialize, Deserialize)]
    pub struct Vocabulary {
        #[serde(flatten)]
        pub stage_vocab: StageVocab,
        pub llm_vocab: Arc<LLMVocab>,
        pub internal_vocab_tree: VocabPrefixTree,
    }

    /// Encapsulates the results of the tokenizer/grammar lookahead analysis.
    #[derive(Debug, Clone, Serialize, Deserialize)]
    pub struct LookaheadData {
        /// Tokenizer state -> grammar terminal -> internal LLM token bitset.
        pub possible_matches: BTreeMap<TokenizerStateID, BTreeMap<TerminalID, LLMTokenBV>>,
        /// Internal-token -> start_tokenizer_state -> end_tokenizer_state.
        pub state_map_by_llm:
            DedupValueMap<LLMTokenID, BTreeMap<TokenizerStateID, TokenizerStateID>>,
        /// Internal-token -> start_tokenizer_state -> terminals.
        pub terminal_map_by_llm:
            DedupValueMap<LLMTokenID, BTreeMap<TokenizerStateID, TerminalBV>>,
    }

    /// Alias for Precomputed4, representing the Dynamic Word Automaton.
    pub type DynamicWordAutomaton = Precomputed4;
}

// ---------------------------------------------------------------------------
// Precomputation Pipeline Stages
// ---------------------------------------------------------------------------

mod pipeline {
    use super::*;
    use super::types::*;
    use super::error::BuildError;
    use super::config::EngineConfig;

    /// Stage 1: Builds the internal vocabulary, runs equivalence analysis, and creates the prefix tree.
    pub fn build_vocabulary(
        llm_token_map: &LLMTokenMap,
        tokenizer: &Regex,
        max_original_llm_token_id: usize,
    ) -> Result<Vocabulary, BuildError> {
        // 1. Equivalence Analysis
        let original_to_internal_map = engine::GrammarEngine::setup_llm_token_mappings(
            llm_token_map,
            tokenizer,
        );
        let internal_max_llm_token = original_to_internal_map
            .values()
            .copied()
            .max()
            .unwrap_or(0);

        let mut internal_to_original_map: BTreeMap<usize, LLMTokenBV> = BTreeMap::new();
        for (orig, int_id) in &original_to_internal_map {
            internal_to_original_map
                .entry(*int_id)
                .or_default()
                .insert(*orig);
        }

        // 2. Build internal LLM token map keyed by bytes.
        let mut internal_llm_token_map: BTreeMap<Vec<u8>, LLMTokenID> = BTreeMap::new();
        for (bytes, original_id) in llm_token_map.iter() {
            if let Some(internal_id_val) = original_to_internal_map.get(&original_id.0) {
                internal_llm_token_map.insert(bytes.clone(), LLMTokenID(*internal_id_val));
            }
        }

        // 3. Vocab tree for internal tokens.
        crate::debug!(3, "Building internal vocab prefix tree");
        let internal_tokens_for_vocab: Vec<(usize, Vec<u8>)> =
            internal_llm_token_map.iter().map(|(b, id)| (id.0, b.clone())).collect();
        let vocab_tree = VocabPrefixTree::build(&internal_tokens_for_vocab);
        crate::debug!(4, "Done building internal vocab prefix tree");

        let stage_vocab = StageVocab {
            original_to_internal: original_to_internal_map,
            internal_to_original: internal_to_original_map,
            internal_max_llm_token,
            max_original_llm_token_id: max_original_llm_token_id,
            internal_to_original_sparse_matrix: vec![], // Will be filled later
        };

        Ok(Vocabulary {
            stage_vocab,
            llm_vocab: Arc::new(LLMVocab {
                llm_token_map: llm_token_map.clone(),
                max_original_llm_token_id,
            }),
            internal_vocab_tree: vocab_tree,
        })
    }

    /// Stage 2: Computes the state transitions and possible terminal matches for all internal tokens.
    pub fn compute_lookaheads(
        tokenizer: &Regex,
        vocab_root: &VocabPrefixTreeNode,
    ) -> Result<LookaheadData, BuildError> {
        crate::debug!(3, "Computing maps and possible_matches (fast parallel pass)");
        let (state_map_by_llm_raw, computed_possible_matches) =
            engine::GrammarEngine::build_maps_and_matches(tokenizer, vocab_root);
        let terminal_map_by_llm_raw =
            engine::GrammarEngine::rearrange_possible_matches(&computed_possible_matches);

        Ok(LookaheadData {
            possible_matches: computed_possible_matches,
            state_map_by_llm: state_map_by_llm_raw,
            terminal_map_by_llm: terminal_map_by_llm_raw,
        })
    }

    /// Stage 3: Runs Precompute1 (Trie), handles ID remapping, and runs Precompute4 (DWA).
    /// Returns the final DWA and the potentially updated Vocabulary and LookaheadData.
    pub fn build_dwa(
        tokenizer: &Regex,
        parser: &GLRParser,
        config: &EngineConfig,
        mut vocabulary: Vocabulary,
        mut lookaheads: LookaheadData,
        token_name_map: &BiBTreeMap<Terminal, usize>,
        original_to_dummy_map: BTreeMap<TerminalID, TerminalID>,
    ) -> Result<(DynamicWordAutomaton, Vocabulary, LookaheadData), BuildError> {
        // 1. Compute terminal follow sets
        crate::debug!(3, "Computing terminal follow sets");
        let terminal_follow_sets_named = compute_terminal_follow_sets(&parser.productions);
        let mut terminal_follow_map: BTreeMap<GrammarTokenID, BTreeSet<GrammarTokenID>> =
            BTreeMap::new();
        for (terminal1, following_terminals) in terminal_follow_sets_named {
            let t1_id = *parser.terminal_map.get_by_left(&terminal1).unwrap();
            let mut following_ids = BTreeSet::new();
            for t2 in following_terminals {
                let t2_id = *parser.terminal_map.get_by_left(&t2).unwrap();
                following_ids.insert(t2_id);
            }
            if !following_ids.is_empty() {
                terminal_follow_map.insert(t1_id, following_ids);
            }
        }

        // 2. Run Precompute1 (Trie)
        let precompute_vocab_before_p1 = vocabulary.stage_vocab.clone();
        let internal_llm_token_map = vocabulary.llm_vocab.llm_token_map.iter()
            .filter_map(|(bytes, original_id)| {
                vocabulary.stage_vocab.original_to_internal.get(&original_id.0)
                    .map(|internal_id| (bytes.clone(), LLMTokenID(*internal_id)))
            })
            .collect();

        let (precomputed1_trie_map, trie1_god_wrapper) = run_precompute1(
            tokenizer,
            Some(parser),
            Some(vocabulary.llm_vocab.clone()),
            &internal_llm_token_map,
            token_name_map,
            &mut vocabulary.stage_vocab,
            &terminal_follow_map,
            config,
            original_to_dummy_map,
        );

        // 3. Handle ID remapping if Trie1 optimization occurred
        let vocab_changed =
            precompute_vocab_before_p1.original_to_internal != vocabulary.stage_vocab.original_to_internal;

        if vocab_changed {
            crate::debug!(3, "Trie1 optimization changed internal LLM IDs. Remapping lookahead data.");
            let mut old_to_new_map = BTreeMap::new();
            for (original_id, old_internal_id) in
                &precompute_vocab_before_p1.original_to_internal
            {
                if let Some(new_internal_id) = vocabulary.stage_vocab.original_to_internal.get(original_id) {
                    old_to_new_map.insert(*old_internal_id, *new_internal_id);
                }
            }

            // Remap possible_matches
            for terminal_map in lookaheads.possible_matches.values_mut() {
                for llm_token_bv in terminal_map.values_mut() {
                    let mut new_bv = LLMTokenBV::zeros();
                    for old_id in llm_token_bv.iter_up_to(usize::MAX) {
                        if let Some(new_id) = old_to_new_map.get(&old_id) {
                            new_bv.insert(*new_id);
                        }
                    }
                    *llm_token_bv = new_bv;
                }
            }

            // Remap state_map_by_llm
            let mut new_state_map_by_llm = DedupValueMap::new();
            for (old_llm_id, value) in lookaheads.state_map_by_llm.iter() {
                if let Some(new_id) = old_to_new_map.get(&old_llm_id.0) {
                    new_state_map_by_llm.insert(LLMTokenID(*new_id), value.clone());
                }
            }
            lookaheads.state_map_by_llm = new_state_map_by_llm;

            // Remap terminal_map_by_llm
            let mut new_terminal_map_by_llm = DedupValueMap::new();
            for (old_llm_id, value) in lookaheads.terminal_map_by_llm.iter() {
                if let Some(new_id) = old_to_new_map.get(&old_llm_id.0) {
                    new_terminal_map_by_llm.insert(LLMTokenID(*new_id), value.clone());
                }
            }
            lookaheads.terminal_map_by_llm = new_terminal_map_by_llm;
        }

        // 4. Convert Trie to NWA and run Precompute4
        crate::debug!(3, "Converting precompute1 Trie to NWA");
        let nwa = convert_precompute1_to_nwa(&precomputed1_trie_map, &trie1_god_wrapper);
        let max_internal_llm_token_id = vocabulary.stage_vocab.internal_max_llm_token;
        let precomputed4 = precompute4(parser, &nwa, max_internal_llm_token_id);

        // 5. Finalize vocabulary sparse matrix
        vocabulary.stage_vocab.internal_to_original_sparse_matrix =
            StageVocab::build_internal_to_original_sparse_matrix(
                &vocabulary.stage_vocab.internal_to_original,
                vocabulary.stage_vocab.max_original_llm_token_id,
                vocabulary.stage_vocab.internal_max_llm_token,
            );

        Ok((precomputed4, vocabulary, lookaheads))
    }
}

// ---------------------------------------------------------------------------
// Grammar Engine (The Immutable Core)
// ---------------------------------------------------------------------------

mod engine {
    use super::*;
    use super::types::*;
    use super::config::EngineConfig;
    use super::error::BuildError;

    #[derive(Debug, Clone, Serialize, Deserialize)]
    pub struct GrammarEngine {
        // Core components
        pub tokenizer: Regex,
        pub parser: GLRParser,

        // Bundled, immutable precomputed data
        pub vocabulary: Arc<Vocabulary>,
        pub lookaheads: Arc<LookaheadData>,
        pub dwa: Arc<DynamicWordAutomaton>,

        // Metadata and configuration
        pub token_name_map: BiBTreeMap<Terminal, usize>,
        pub original_to_dummy_map: BTreeMap<TerminalID, TerminalID>,
        pub run_precompute4: bool,
        pub post_commit_allow_check_mode: config::TerminalAllowanceCheckMode,

        // Note: precomputed1 and trie1_god are discarded after DWA generation
        #[serde(skip)]
        pub(crate) _trie1_god_wrapper: Trie1GodWrapper,
    }

    impl GrammarEngine {
        // --- Internal Helpers (Moved from original impl) ---

        pub(crate) fn setup_llm_token_mappings(
            original_llm_token_map: &LLMTokenMap,
            tokenizer: &Regex,
        ) -> BTreeMap<usize, usize> {
            // ... (Implementation remains the same) ...
            if original_llm_token_map.len() < 10 {
                return original_llm_token_map
                    .iter()
                    .map(|(_bytes, id)| (id.0, id.0))
                    .collect();
            }

            let mut sorted_tokens: Vec<_> = original_llm_token_map.iter().collect();
            sorted_tokens.sort_by_key(|(bytes, _id)| *bytes);

            let mut llm_token_strings: Vec<Vec<u8>> = Vec::with_capacity(sorted_tokens.len());
            let mut original_ids: Vec<LLMTokenID> = Vec::with_capacity(sorted_tokens.len());

            for (bytes, id) in sorted_tokens {
                llm_token_strings.push(bytes.clone());
                original_ids.push(*id);
            }

            let initial_states: Vec<usize> = tokenizer.iter_states().map(|s| s.0).collect();

            let equivalence_classes =
                equivalence_analysis_finite_automata::find_equivalence_classes(
                    tokenizer,
                    &llm_token_strings,
                    &initial_states,
                );

            if is_debug_level_enabled(3) {
                let num_original_tokens = llm_token_strings.len();
                let num_classes = equivalence_classes.len();
                crate::debug!(3, "Equivalence Analysis: {} original tokens -> {} classes", num_original_tokens, num_classes);
            }

            let mut original_to_internal_map = BTreeMap::new();
            let mut internal_id_counter = 0;
            for (_signature, string_indices) in equivalence_classes {
                let internal_id = internal_id_counter;
                internal_id_counter += 1;
                for string_index in string_indices {
                    let original_llm_id = original_ids[string_index];
                    original_to_internal_map.insert(original_llm_id.0, internal_id);
                }
            }

            original_to_internal_map
        }

        pub(crate) fn build_maps_and_matches(
            tokenizer: &Regex,
            vocab_root: &VocabPrefixTreeNode,
        ) -> (
            DedupValueMap<LLMTokenID, BTreeMap<TokenizerStateID, TokenizerStateID>>,
            BTreeMap<TokenizerStateID, BTreeMap<TerminalID, LLMTokenBV>>,
        ) {
            // ... (Implementation remains the same, using the fast parallel pass) ...
            // Flatten DFA for fast access (u32::MAX represents None)
            struct FastDFA {
                transitions: Vec<u32>,           // size = num_states * 256
                finalizers: Vec<Vec<TerminalID>>, // size = num_states
            }

            // Recursive DFS helper
            fn process_vocab_node_dfs(
                node: &VocabPrefixTreeNode,
                current_states: Vec<(u32, Vec<u32>)>,
                dfa: &FastDFA,
                out_state_map: &mut Vec<(LLMTokenID, BTreeMap<TokenizerStateID, TokenizerStateID>)>,
                out_matches: &mut BTreeMap<TokenizerStateID, BTreeMap<TerminalID, LLMTokenBV>>,
            ) {
                for (edge_bytes, child) in node.iter_children() {
                    let mut next_grouped_map: HashMap<u32, Vec<u32>> = HashMap::new();
                    let reachable_bv: LLMTokenBV = child.reachable_token_ids().into();

                    for (start, sources) in &current_states {
                        let mut curr = *start;
                        let mut valid = true;

                        for &b in edge_bytes.iter() {
                            let offset = (curr as usize) * 256 + (b as usize);
                            let next = dfa.transitions[offset];
                            if next == u32::MAX {
                                valid = false;
                                break;
                            }
                            curr = next;

                            // If matched, record for all sources
                            if !dfa.finalizers[curr as usize].is_empty() {
                                for &tid in &dfa.finalizers[curr as usize] {
                                    for &src in sources {
                                        out_matches
                                            .entry(TokenizerStateID(src as usize))
                                            .or_default()
                                            .entry(tid)
                                            .or_default()
                                            .union_with(&reachable_bv);
                                    }
                                }
                            }
                        }

                        if valid {
                            next_grouped_map.entry(curr).or_default().extend_from_slice(sources);
                        }
                    }

                    let next_grouped: Vec<(u32, Vec<u32>)> =
                        next_grouped_map.into_iter().collect();

                    if !next_grouped.is_empty() {
                        // Record state map
                        let mut map = BTreeMap::new();
                        for (target, sources) in &next_grouped {
                            let tgt = TokenizerStateID(*target as usize);
                            for &src in sources {
                                map.insert(TokenizerStateID(src as usize), tgt);
                            }
                        }
                        out_state_map.push((LLMTokenID(child.token_id()), map));

                        // Recurse
                        process_vocab_node_dfs(
                            child,
                            next_grouped,
                            dfa,
                            out_state_map,
                            out_matches,
                        );
                    }
                }
            }

            let dfa = &tokenizer.dfa;
            let num_states = dfa.states.len();
            let mut transitions = vec![u32::MAX; num_states * 256];
            let mut finalizers = Vec::with_capacity(num_states);

            for (i, state) in dfa.states.iter().enumerate() {
                for (byte, &next) in &state.transitions {
                    transitions[i * 256 + (byte as usize)] = next as u32;
                }
                finalizers.push(
                    state
                        .finalizers
                        .iter()
                        .map(|&gid| TerminalID(gid))
                        .collect(),
                );
            }

            let fast_dfa = FastDFA {
                transitions,
                finalizers,
            };

            // Group initial states by current state (identity mapping at root)
            let mut initial_states: Vec<(u32, Vec<u32>)> = Vec::with_capacity(num_states);
            for i in 0..num_states {
                initial_states.push((i as u32, vec![i as u32]));
            }

            // Parallel processing of root children
            let root_children: Vec<_> = vocab_root.iter_children().collect();
            let results: Vec<_> = root_children
                .par_iter()
                .map(|(edge_bytes, child_node)| {
                    let mut local_state_map_entries = Vec::new();
                    let mut local_possible_matches: BTreeMap<
                        TokenizerStateID,
                        BTreeMap<TerminalID, LLMTokenBV>,
                    > = BTreeMap::new();

                    // Manually process the first edge to bootstrap recursion
                    let mut next_grouped_map: HashMap<u32, Vec<u32>> = HashMap::new();
                    let reachable_bv: LLMTokenBV =
                        child_node.reachable_token_ids().into();

                    for (start, sources) in &initial_states {
                        let mut curr = *start;
                        let mut valid = true;
                        for &b in edge_bytes.iter() {
                            let offset = (curr as usize) * 256 + (b as usize);
                            let next = fast_dfa.transitions[offset];
                            if next == u32::MAX {
                                valid = false;
                                break;
                            }
                            curr = next;
                            if !fast_dfa.finalizers[curr as usize].is_empty() {
                                for &tid in &fast_dfa.finalizers[curr as usize] {
                                    for &src in sources {
                                        local_possible_matches
                                            .entry(TokenizerStateID(src as usize))
                                            .or_default()
                                            .entry(tid)
                                            .or_default()
                                            .union_with(&reachable_bv);
                                    }
                                }
                            }
                        }
                        if valid {
                            next_grouped_map.entry(curr).or_default().extend_from_slice(sources);
                        }
                    }

                    let next_grouped: Vec<(u32, Vec<u32>)> =
                        next_grouped_map.into_iter().collect();
                    if !next_grouped.is_empty() {
                        let mut map = BTreeMap::new();
                        for (target, sources) in &next_grouped {
                            let tgt = TokenizerStateID(*target as usize);
                            for &src in sources {
                                map.insert(TokenizerStateID(src as usize), tgt);
                            }
                        }
                        local_state_map_entries
                            .push((LLMTokenID(child_node.token_id()), map));

                        process_vocab_node_dfs(
                            child_node,
                            next_grouped,
                            &fast_dfa,
                            &mut local_state_map_entries,
                            &mut local_possible_matches,
                        );
                    }

                    (local_state_map_entries, local_possible_matches)
                })
                .collect();

            // Merge
            let mut state_map_out = DedupValueMap::new();
            // Root identity
            {
                let mut root_map = BTreeMap::new();
                for i in 0..num_states {
                    let s = TokenizerStateID(i);
                    root_map.insert(s, s);
                }
                state_map_out.insert(LLMTokenID(vocab_root.token_id()), root_map);
            }

            let mut possible_matches: BTreeMap<
                TokenizerStateID,
                BTreeMap<TerminalID, LLMTokenBV>,
            > = BTreeMap::new();
            for (entries, matches) in results {
                for (tid, map) in entries {
                    state_map_out.insert(tid, map);
                }
                for (sid, term_map) in matches {
                    let target = possible_matches.entry(sid).or_default();
                    for (tid, bv) in term_map {
                        target.entry(tid).or_default().union_with(&bv);
                    }
                }
            }

            (state_map_out, possible_matches)
        }

        pub(crate) fn rearrange_possible_matches(
            pm: &BTreeMap<TokenizerStateID, BTreeMap<TerminalID, LLMTokenBV>>,
        ) -> DedupValueMap<LLMTokenID, BTreeMap<TokenizerStateID, TerminalBV>> {
            // ... (Implementation remains the same) ...
            let mut triples: Vec<(u32, u32, u32)> = pm
                .par_iter()
                .flat_map(|(sid, tmap)| {
                    let mut local_triples = Vec::new();
                    for (term, bv) in tmap {
                        if !bv.is_all() {
                            for tok in bv.iter_up_to(usize::MAX) {
                                local_triples
                                    .push((tok as u32, sid.0 as u32, term.0 as u32));
                            }
                        }
                    }
                    local_triples
                })
                .collect();

            triples.par_sort_unstable_by_key(|t| t.0);

            let mut out = DedupValueMap::new();
            if triples.is_empty() {
                return out;
            }

            let mut current_token = triples[0].0;
            let mut current_map: BTreeMap<TokenizerStateID, TerminalBV> = BTreeMap::new();

            for (tok, sid, term) in triples {
                if tok != current_token {
                    out.insert(LLMTokenID(current_token as usize), current_map);
                    current_map = BTreeMap::new();
                    current_token = tok;
                }
                current_map
                    .entry(TokenizerStateID(sid as usize))
                    .or_default()
                    .insert(term as usize);
            }
            out.insert(LLMTokenID(current_token as usize), current_map);

            out
        }

        // --- Public API Methods ---

        pub fn init(self: &Arc<Self>) -> ConstraintState {
            let mut state = BTreeMap::new();
            state.insert(
                self.tokenizer.initial_state_id(),
                self.parser.init_glr_parser(Some(self.vocabulary.llm_vocab.clone())),
            );
            ConstraintState { engine: self.clone(), active_states: state }
        }

        // Vocab helpers (delegated to the Vocabulary struct)
        pub fn all_internal_llm_tokens_bitset(&self) -> LLMTokenBV {
            LLMTokenBV::ones(self.vocabulary.stage_vocab.internal_max_llm_token + 1)
        }

        pub fn internal_bv_to_original(&self, internal_bv: &LLMTokenBV) -> Bitset {
            self.vocabulary.stage_vocab.internal_bv_to_original(internal_bv)
        }

        pub fn original_bv_to_internal(&self, original_bv: &LLMTokenBV) -> LLMTokenBV {
            self.vocabulary.stage_vocab.original_bv_to_internal(original_bv)
        }
    }

    // Keeping JSONConvertible for compatibility, delegating to serde
    impl JSONConvertible for GrammarEngine {
        fn to_json(&self) -> JSONNode {
            match serde_json::to_value(self) {
                Ok(v) => JSONNode::from_value(v),
                Err(e) => panic!("Serialization error: {}", e),
            }
        }

        fn from_json(node: JSONNode) -> Result<Self, String> {
            let value = node.to_value();
            serde_json::from_value(value).map_err(|e| format!("Deserialization error: {}", e))
        }
    }
}

// ---------------------------------------------------------------------------
// Grammar Engine Builder
// ---------------------------------------------------------------------------

mod builder {
    use super::*;
    use super::engine::GrammarEngine;
    use super::config::EngineConfig;
    use super::error::BuildError;
    use super::pipeline;

    pub struct GrammarEngineBuilder {
        grammar: CompiledGrammar,
        llm_token_map: LLMTokenMap,
        max_original_llm_token_id: usize,
        config: EngineConfig,
    }

    impl GrammarEngineBuilder {
        pub fn new(
            grammar: CompiledGrammar,
            llm_token_map: LLMTokenMap,
            max_original_llm_token_id: usize,
        ) -> Self {
            Self {
                grammar,
                llm_token_map,
                max_original_llm_token_id,
                config: EngineConfig::default(),
            }
        }

        pub fn with_config(mut self, config: EngineConfig) -> Self {
            self.config = config;
            self
        }

        /// Convenience entry point from a `GrammarDefinition`.
        pub fn from_grammar_definition(
            grammar_definition: Arc<GrammarDefinition>,
            llm_token_map: LLMTokenMap,
            max_original_llm_token_id: usize,
            config: &EngineConfig,
        ) -> Result<Self, BuildError> {
            let initial_compiled_grammar =
                CompiledGrammar::from_definition(grammar_definition.clone());

            let mut original_to_dummy_map: BTreeMap<TerminalID, TerminalID> = BTreeMap::new();

            let final_compiled_grammar = if config.use_dummy_terminals {
                let (final_productions, new_dummy_terminals) =
                    crate::glr::analyze::rewrite_productions_with_dummies(
                        &grammar_definition.productions,
                        &config.dummy_terminal_map,
                    );

                let final_compiled_grammar = if !new_dummy_terminals.is_empty() {
                    let mut final_grammar_def = (*grammar_definition).clone();
                    final_grammar_def.productions = final_productions;
                    for dummy_terminal in new_dummy_terminals {
                        if let Terminal::RegexName(name) = dummy_terminal {
                            final_grammar_def.add_external_terminal(&name);
                        }
                    }
                    CompiledGrammar::from_definition(Arc::new(final_grammar_def))
                } else {
                    initial_compiled_grammar
                };

                // Populate original_to_dummy_map
                for (dummy_name, original_terminals) in &config.dummy_terminal_map {
                    let dummy_term = Terminal::regex_name(dummy_name);
                    if let Some(&dummy_id) = final_compiled_grammar.glr_parser.terminal_map.get_by_left(&dummy_term) {
                        for original_terminal in original_terminals {
                            if let Some(&original_id) =
                                final_compiled_grammar.glr_parser.terminal_map.get_by_left(original_terminal)
                            {
                                original_to_dummy_map.insert(original_id, dummy_id);
                            }
                        }
                    }
                }
                final_compiled_grammar
            } else {
                initial_compiled_grammar
            };

            let mut builder = Self::new(
                final_compiled_grammar,
                llm_token_map,
                max_original_llm_token_id,
            ).with_config(config.clone());

            builder.original_to_dummy_map = original_to_dummy_map;
            Ok(builder)
        }

        // Internal field to hold the map during the build process
        original_to_dummy_map: BTreeMap<TerminalID, TerminalID>,
        
        pub fn build(self) -> Result<GrammarEngine, BuildError> {
            // Epsilon tokens check
            let epsilon_terminal_group_ids: BTreeSet<_> = self.grammar.tokenizer
                .execute_from_state(&[], self.grammar.tokenizer.initial_state_id())
                .matches
                .iter()
                .map(|token| token.id)
                .collect();
            if !epsilon_terminal_group_ids.is_empty() {
                return Err(BuildError::EpsilonTokenNotSupported);
            }

            // Stage 1: Vocabulary & Equivalence Analysis
            crate::debug!(2, "Stage 1: Building vocabulary and running equivalence analysis...");
            let vocabulary = pipeline::build_vocabulary(
                &self.llm_token_map,
                &self.grammar.tokenizer,
                self.max_original_llm_token_id,
            )?;

            // Stage 2: Compute Lookaheads
            crate::debug!(2, "Stage 2: Pre-computing token lookaheads...");
            let lookaheads = pipeline::compute_lookaheads(
                &self.grammar.tokenizer,
                &vocabulary.internal_vocab_tree.root,
            )?;

            // Stage 3: Build Dynamic Word Automaton (DWA)
            crate::debug!(2, "Stage 3: Building Dynamic Word Automaton (DWA)...");
            let (dwa, final_vocabulary, final_lookaheads) = pipeline::build_dwa(
                &self.grammar.tokenizer,
                &self.grammar.glr_parser,
                &self.config,
                vocabulary,
                lookaheads,
                self.grammar.definition.terminal_to_group_id(),
                self.original_to_dummy_map.clone(),
            )?;

            // Stage 4: Assemble the final engine
            crate::debug!(2, "Stage 4: Assembling final grammar engine...");
            Ok(GrammarEngine {
                tokenizer: self.grammar.tokenizer,
                parser: self.grammar.glr_parser,
                token_name_map: self.grammar.definition.terminal_to_group_id().clone(),
                original_to_dummy_map: self.original_to_dummy_map,
                run_precompute4: self.config.run_precompute4,
                post_commit_allow_check_mode: self.config.post_commit_allow_check_mode,
                
                vocabulary: Arc::new(final_vocabulary),
                lookaheads: Arc::new(final_lookaheads),
                dwa: Arc::new(dwa),
                _trie1_god_wrapper: Trie1GodWrapper::new(), // Empty wrapper, as trie is discarded
            })
        }
    }
}

// ---------------------------------------------------------------------------
// Runtime State
// ---------------------------------------------------------------------------

mod state {
    use super::*;
    use super::engine::GrammarEngine;

    // Note: Assuming GLRParserState is now decoupled from lifetimes internally
    // or that the GLRParser reference it holds is Arc'd.
    #[derive(Debug, Clone)]
    pub struct ConstraintState {
        engine: Arc<GrammarEngine>,
        pub active_states: BTreeMap<TokenizerStateID, GLRParserState>,
    }

    impl PartialEq for ConstraintState {
        fn eq(&self, other: &Self) -> bool {
            Arc::ptr_eq(&self.engine, &other.engine) && self.active_states == other.active_states
        }
    }

    impl Eq for ConstraintState {}

    impl Display for ConstraintState {
        fn fmt(&self, f: &mut Formatter<'_>) -> fmt::Result {
            writeln!(
                f,
                "ConstraintState ({} active tokenizer states):",
                self.active_states.len()
            )?;
            Ok(())
        }
    }

    impl ConstraintState {
        pub fn engine(&self) -> &Arc<GrammarEngine> {
            &self.engine
        }

        pub fn state(&self) -> &BTreeMap<TokenizerStateID, GLRParserState> {
            &self.active_states
        }

        pub fn is_active(&self) -> bool { !self.active_states.is_empty() }

        pub fn commit(&mut self, llm_token_id: LLMTokenID) {
            self.commit_bytes(
                &self
                    .engine
                    .vocabulary
                    .llm_vocab
                    .llm_token_map
                    .get_by_right(&llm_token_id)
                    .unwrap()
                    .clone(),
            );
        }

        pub fn commit_bytes(&mut self, llm_token_bytes: &[u8]) {
            let (state_map, terminals_map) = self.compute_commit_maps(llm_token_bytes);

            let mut next_state: BTreeMap<TokenizerStateID, GLRParserState> = BTreeMap::new();

            for (start_tid, mut glr_state) in self.active_states.drain() {
                if let Some(end_tid) = state_map.get(&start_tid) {
                    if let Some(terminals_bv) = terminals_map.get(&start_tid) {
                        // Perform GLR steps for all matched terminals
                        for gtid in terminals_bv.iter_up_to(usize::MAX) {
                            let mut stepped_state = glr_state.clone();
                            stepped_state.step(TerminalID(gtid));

                            if stepped_state.is_ok() {
                                // Merge the resulting GLR state into the target tokenizer state
                                next_state
                                    .entry(*end_tid)
                                    .or_insert_with(|| stepped_state.clone())
                                    .merge_from(stepped_state);
                            }
                        }
                    }
                }
            }
            self.active_states = next_state;
        }

        pub fn compute_commit_maps(
            &self,
            llm_token_bytes: &[u8],
        ) -> (
            BTreeMap<TokenizerStateID, TokenizerStateID>,
            BTreeMap<TokenizerStateID, TerminalBV>,
        ) {
            let mut state_map: BTreeMap<TokenizerStateID, TokenizerStateID> =
                BTreeMap::new();
            let mut terminals_map: BTreeMap<TokenizerStateID, TerminalBV> =
                BTreeMap::new();
            for (tokenizer_state_id, _state) in self.active_states.iter() {
                let exec_result = self.engine.tokenizer.execute_from_state(
                    &llm_token_bytes,
                    *tokenizer_state_id,
                );
                if let Some(new_state) = exec_result.end_state {
                    state_map.insert(*tokenizer_state_id, TokenizerStateID(new_state));
                }
                let mut terminals = TerminalBV::zeros();
                for token in exec_result.matches {
                    terminals.insert(token.id);
                }
                terminals_map.insert(*tokenizer_state_id, terminals);
            }
            (state_map, terminals_map)
        }

        pub fn get_mask(&self) -> LLMTokenBV {
            // Placeholder for the actual mask computation logic (get_mask4)
            // This would typically involve querying the DWA (self.engine.dwa)
            // and the current GSS nodes.
            self.engine.all_internal_llm_tokens_bitset()
        }

        // ... other methods (transform_gss_stacks, map_gss_stacks, print_gss_stats, etc.)
        // These methods would be updated to use `self.active_states` and `self.engine`.
    }
}

// ---------------------------------------------------------------------------
// Merge implementation for leveled GSS (Kept at top level for visibility)
// ---------------------------------------------------------------------------

impl Merge for RangeSetBlaze<usize> {
    fn merge(&self, other: &Self) -> Self { self | other }
}

impl Merge for Arc<RangeSetBlaze<usize>> {
    fn merge(&self, other: &Self) -> Self {
        if Arc::ptr_eq(self, other) {
            return self.clone();
        }
        let mut merged = self.as_ref().clone();
        merged |= other.as_ref();
        if merged == **self {
            self.clone()
        } else if merged == **other {
            other.clone()
        } else {
            Arc::new(merged)
        }
    }
}