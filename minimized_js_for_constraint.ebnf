private_identifier ::= '#' IDENTIFIER ;
program ::= program[0] EOF ;
program[0] ::= statement_list
  |  ;
property_assignment ::= property_assignment[0] property_assignment[1] property_name '(' property_assignment[2] ')' block
  | 'get' property_name '(' ')' block
