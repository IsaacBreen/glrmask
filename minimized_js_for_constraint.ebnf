additive_expression ::= multiplicative_expression additive_expression[0] ;
additive_expression[0] ::= additive_expression[0] additive_expression[0][0] multiplicative_expression
  |  ;
additive_expression[0][0] ::= '+'
  | '-' ;
arguments ::= '(' arguments[0] ')' ;
arguments[0] ::= assignment_expression arguments[0][0]
  |  ;
arguments[0][0] ::= arguments[0][0] ',' assignment_expression
  |  ;
array_binding_pattern ::= '[' array_binding_pattern[0] array_binding_pattern[1] array_binding_pattern[2] array_binding_pattern[3] array_binding_pattern[4] ']' ;
array_binding_pattern[0] ::= array_binding_pattern[0][0] binding_element
  |  ;
array_binding_pattern[0][0] ::= ELISION
  |  ;
array_binding_pattern[1] ::= array_binding_pattern[1] ',' array_binding_pattern[1][0] binding_element
  |  ;
array_binding_pattern[1][0] ::= ELISION
  |  ;
