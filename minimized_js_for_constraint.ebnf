assignment_expression[0] ::= '='
  | '+='
  | '-='
  | '*='
  | '/='
  | '%='
  | '<<='
  | '>>='
  | '>>>='
  | '&='
  | '^='
  | '|='
  | '**=' ;
binding_element ::= binding_pattern binding_element[0] ;
binding_element[0] ::= '=' expression
  |  ;
binding_pattern ::= IDENTIFIER
  | object_binding_pattern
  | array_binding_pattern ;
bitwise_and_expression ::= equality_expression bitwise_and_expression[0] ;
bitwise_and_expression[0] ::= bitwise_and_expression[0] '&' equality_expression
  |  ;
bitwise_or_expression ::= bitwise_xor_expression bitwise_or_expression[0] ;
bitwise_or_expression[0] ::= bitwise_or_expression[0] '|' bitwise_xor_expression
  |  ;
bitwise_xor_expression ::= bitwise_and_expression bitwise_xor_expression[0] ;
bitwise_xor_expression[0] ::= bitwise_xor_expression[0] '^' bitwise_and_expression
  |  ;
block ::= '{' block[0] '}' ;
block[0] ::= statement_list
  |  ;
break_statement ::= 'break' break_statement[0] break_statement[1] ;
break_statement[0] ::= IDENTIFIER
  |  ;
break_statement[1] ::= ';'
  |  ;
call_expression ::= member_expression arguments
  | 'super' arguments
  | call_expression arguments
  | call_expression '?.' arguments
  | call_expression '[' expression ']'
  | call_expression '?.' '[' expression ']'
  | call_expression '.' IDENTIFIER
  | call_expression '?.' IDENTIFIER
  | call_expression '.' private_identifier
  | call_expression '?.' private_identifier
  | call_expression template_literal ;
case_clause ::= 'case' expression ':' case_clause[0] ;
case_clause[0] ::= statement_list
  |  ;
case_clauses ::= case_clause case_clauses[0] ;
case_clauses[0] ::= case_clauses[0] case_clause
  |  ;
catch_clause ::= 'catch' catch_clause[0] block ;
catch_clause[0] ::= '(' binding_pattern ')'
  |  ;
class_body ::= '{' class_body[0] '}' ;
class_body[0] ::= class_body[0] class_member
  |  ;
class_declaration ::= 'class' class_declaration[0] class_declaration[1] class_body ;
class_declaration[0] ::= IDENTIFIER
  |  ;
class_declaration[1] ::= 'extends' expression
  |  ;
class_member ::= class_member[0] class_member[1]
  | ';' ;
class_member[0] ::= method_definition
  | field_definition ;
class_member[1] ::= ';'
  |  ;
class_property_name ::= property_name
  | private_identifier ;
coalesce_expression ::= logical_or_expression coalesce_expression[0] ;
coalesce_expression[0] ::= coalesce_expression[0] '??' logical_or_expression
  |  ;
conditional_expression ::= coalesce_expression conditional_expression[0] ;
conditional_expression[0] ::= '?' assignment_expression ':' assignment_expression
  |  ;
continue_statement ::= 'continue' continue_statement[0] continue_statement[1] ;
continue_statement[0] ::= IDENTIFIER
  |  ;
continue_statement[1] ::= ';'
  |  ;
debugger_statement ::= 'debugger' debugger_statement[0] ;
debugger_statement[0] ::= ';'
  |  ;
declaration_statement ::= declaration_statement[0] variable_declaration_list declaration_statement[1] ;
declaration_statement[0] ::= 'var'
  | 'let'
  | 'const' ;
declaration_statement[1] ::= ';'
  |  ;
default_clause ::= 'default' ':' default_clause[0] ;
default_clause[0] ::= statement_list
  |  ;
default_import ::= IDENTIFIER ;
equality_expression ::= relational_expression equality_expression[0] ;
equality_expression[0] ::= equality_expression[0] equality_expression[0][0] relational_expression
  |  ;
equality_expression[0][0] ::= '=='
  | '!='
  | '==='
  | '!==' ;
exponentiation_expression ::= unary_expression exponentiation_expression[0] ;
exponentiation_expression[0] ::= '**' exponentiation_expression
  |  ;
export_specifier ::= IDENTIFIER export_specifier[0] ;
export_specifier[0] ::= 'as' IDENTIFIER
  |  ;
export_statement ::= 'export' export_statement[0] export_statement[1] ;
export_statement[0] ::= 'default' export_statement[0][0]
  | '*' export_statement[0][1]
