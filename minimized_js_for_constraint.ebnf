relational_expression ::= shift_expression relational_expression[0] ;
relational_expression[0] ::= relational_expression[0] relational_expression[0][0] shift_expression
  |  ;
relational_expression[0][0] ::= '<'
  | '>'
  | '<='
  | '>='
  | 'instanceof'
  | 'in' ;
return_statement ::= 'return' return_statement[0] return_statement[1] ;
return_statement[0] ::= expression
  |  ;
return_statement[1] ::= ';'
  |  ;
shift_expression ::= additive_expression shift_expression[0] ;
shift_expression[0] ::= shift_expression[0] shift_expression[0][0] additive_expression
