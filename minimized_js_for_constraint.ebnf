literal ::= NULL_LITERAL
  | BOOLEAN_LITERAL
  | NUMERIC_LITERAL
  | BIGINT_LITERAL
  | STRING_LITERAL
  | REGULAR_EXPRESSION_LITERAL
  | template_literal ;
logical_and_expression ::= bitwise_or_expression logical_and_expression[0] ;
logical_and_expression[0] ::= logical_and_expression[0] '&&' bitwise_or_expression
  |  ;
logical_or_expression ::= logical_and_expression logical_or_expression[0] ;
logical_or_expression[0] ::= logical_or_expression[0] '||' logical_and_expression
  |  ;
member_expression ::= primary_expression
  | member_expression '[' expression ']'
  | member_expression '?.' '[' expression ']'
