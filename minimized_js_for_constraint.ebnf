method_definition ::= method_definition[0] method_definition[1] method_definition[2] class_property_name '(' method_definition[3] ')' block ;
method_definition[0] ::= 'static'
  |  ;
method_definition[1] ::= method_definition[1][0]
  |  ;
method_definition[1][0] ::= 'get'
  | 'set' ;
method_definition[2] ::= method_definition[2][0]
  |  ;
method_definition[2][0] ::= 'async'
  | '*' ;
method_definition[3] ::= parameter_list
  |  ;
multiplicative_expression ::= exponentiation_expression multiplicative_expression[0] ;
multiplicative_expression[0] ::= multiplicative_expression[0] multiplicative_expression[0][0] exponentiation_expression
  |  ;
multiplicative_expression[0][0] ::= '*'
  | '/'
  | '%' ;
named_exports ::= '{' named_exports[0] named_exports[1] '}' ;
named_exports[0] ::= export_specifier named_exports[0][0]
  |  ;
named_exports[0][0] ::= named_exports[0][0] ',' export_specifier
