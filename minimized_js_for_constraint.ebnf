  | declaration_statement
  | class_declaration ;
export_statement[0][0] ::= function_declaration
  | class_declaration
  | expression ;
export_statement[0][1] ::= 'from' STRING_LITERAL
  |  ;
export_statement[0][2] ::= 'from' STRING_LITERAL
  |  ;
export_statement[1] ::= ';'
  |  ;
expression ::= assignment_expression ;
expression_statement ::= expression expression_statement[0] ;
expression_statement[0] ::= ';'
  |  ;
field_definition ::= field_definition[0] class_property_name field_definition[1] ;
field_definition[0] ::= 'static'
  |  ;
field_definition[1] ::= '=' expression
  |  ;
finally_clause ::= 'finally' block ;
formal_parameter ::= binding_pattern formal_parameter[0] ;
formal_parameter[0] ::= '=' expression
  |  ;
function_declaration ::= function_declaration[0] 'function' function_declaration[1] function_declaration[2] '(' function_declaration[3] ')' block ;
function_declaration[0] ::= 'async'
  |  ;
function_declaration[1] ::= '*'
  |  ;
function_declaration[2] ::= IDENTIFIER
  |  ;
function_declaration[3] ::= parameter_list
  |  ;
function_expression ::= function_expression[0] 'function' function_expression[1] function_expression[2] '(' function_expression[3] ')' block ;
function_expression[0] ::= 'async'
  |  ;
function_expression[1] ::= '*'
  |  ;
function_expression[2] ::= IDENTIFIER
  |  ;
function_expression[3] ::= parameter_list
  |  ;
if_statement ::= 'if' '(' expression ')' statement if_statement[0] ;
if_statement[0] ::= 'else' statement
  |  ;
import_clause ::= default_import
  | named_imports
  | namespace_import
  | default_import ',' import_clause[0] ;
import_clause[0] ::= named_imports
  | namespace_import ;
import_specifier ::= IDENTIFIER import_specifier[0] ;
import_specifier[0] ::= 'as' IDENTIFIER
  |  ;
import_statement ::= 'import' import_statement[0] import_statement[1] ;
import_statement[0] ::= import_clause 'from' STRING_LITERAL
  | STRING_LITERAL ;
import_statement[1] ::= ';'
  |  ;
iteration_statement ::= 'while' '(' expression ')' statement
  | 'do' statement 'while' '(' expression ')' ';'
  | 'for' '(' iteration_statement[0] ';' iteration_statement[1] ';' iteration_statement[2] ')' statement
  | 'for' '(' iteration_statement[3] binding_pattern iteration_statement[4] expression ')' statement
  | 'for' '(' iteration_statement[5] ';' iteration_statement[6] ';' iteration_statement[7] ')' statement ;
iteration_statement[0] ::= iteration_statement[0][0] variable_declaration_list
  |  ;
iteration_statement[0][0] ::= 'var'
  | 'let'
  | 'const' ;
iteration_statement[1] ::= expression
  |  ;
iteration_statement[2] ::= expression
  |  ;
iteration_statement[3] ::= iteration_statement[3][0]
  |  ;
iteration_statement[3][0] ::= 'var'
  | 'let'
  | 'const' ;
iteration_statement[4] ::= 'in'
  | 'of' ;
iteration_statement[5] ::= expression
  |  ;
iteration_statement[6] ::= expression
  |  ;
iteration_statement[7] ::= expression
  |  ;
labeled_statement ::= IDENTIFIER ':' statement ;
left_hand_side_expression ::= new_expression
