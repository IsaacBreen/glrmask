  |  ;
array_binding_pattern[2][0] ::= ','
  |  ;
array_binding_pattern[3] ::= ','
  |  ;
array_binding_pattern[4] ::= ELISION
  |  ;
array_literal ::= '[' array_literal[0] array_literal[1] array_literal[2] array_literal[3] ']' ;
array_literal[0] ::= array_literal[0][0] assignment_expression
  |  ;
array_literal[0][0] ::= ELISION
  |  ;
array_literal[1] ::= array_literal[1] ',' array_literal[1][0] assignment_expression
