object_binding_pattern[1] ::= object_binding_pattern[1][0] '...' IDENTIFIER
  |  ;
object_binding_pattern[1][0] ::= ','
  |  ;
object_binding_pattern[2] ::= ','
  |  ;
object_literal ::= '{' object_literal[0] object_literal[1] '}' ;
object_literal[0] ::= property_assignment object_literal[0][0]
